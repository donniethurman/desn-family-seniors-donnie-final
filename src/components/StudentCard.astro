---
import { Image } from "astro:assets";
const { name, image, favorite_emoji, bio, song, quote, yourURL } = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, "-");
const songUrl = song ? (song.startsWith('http') ? song : `https://${song}`) : null;
---

<a href={`/${slug}`} class="card-link">
  <figure class="card">
    <figcaption class="card-name" transition:name={`name-${slug}`}>
      <div class="card-header">
        <span class="name">{name}</span>
        {favorite_emoji && <span class="card-emoji">{favorite_emoji}</span>}
      </div>

      {song && (
        <div class="card-links">
          <button type="button" class="song-button" onclick={`window.open(${JSON.stringify(songUrl)}, '_blank')`}>
            Song
          </button>
        </div>
      )}

      {quote && <p class="card-quote">{quote}</p>}
    </figcaption>

    <Image src={image} alt={name} widths={[400, 800]} sizes="(max-width: 600px) 100vw, 400px" inferSize={typeof image === "string"} transition:name={`photo-${slug}`} />
  </figure>
</a>

<style>
  .card {
    border: 0;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border: 1px solid lightgray;
    background-color: #FFF4EB;
    border-radius: 1rem;
    flex: 1;
    overflow: hidden;
  }

  .card :global(img) {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border-radius: 1rem;
  }

  .card:hover {
    background: #a6bcc9;
    transition: background-color 0.3s;
  }
  .card-name {
    font-size: 1.25rem;
    font-weight: bold;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0 auto;
    text-align: center;
    margin-top: 0.5rem;
    }

  .card-emoji {
  
  }

  .card-quote {
    font-style: italic;
    color: black;
    font-family:Arial, Helvetica, sans-serif;
    font-size: 0.9rem;
    font-weight: normal;
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .card-links {
    display: flex;
    gap: 0.75rem;
    margin-top: auto;
  }

  .song-button {
    appearance: none;
    -webkit-appearance: none;
    background: #3B4B8E;
    color: #fff4eb;
    border: 1px solid goldenrod;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    font: inherit;
    font-size: 0.9rem;
    border-radius: 2rem;
    margin: 0 auto;
    margin-bottom: 0.5rem;
    margin-top: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .song-button:hover {
    background: goldenrod;
    color: white;
    transition: background-color 0.3s, color 0.3s;
  }
  .card-links a {
    text-decoration: none;
    color: goldenrod;
    border-bottom: 1px solid currentColor;
  }

  .card-links a:hover {
    background: gray;
    color: white;
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    aspect-ratio: 1 / 1;
  }

  .card {
    flex: 1;
    overflow: hidden;
  }

  .card-link:hover .card {
    border-color: goldenrod;
  }
</style>
